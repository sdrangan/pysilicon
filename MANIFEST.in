# Include top-level documentation
include README.md
include LICENSE

# Include everything in docs/ for GitHub Pages and local builds
recursive-include docs *

# Include example projects (e.g., waveflow)
recursive-include examples *

# Include non-Python files inside the waveflow package
recursive-include waveflow *.json
recursive-include waveflow *.yaml
recursive-include waveflow *.yml
recursive-include waveflow *.txt
recursive-include waveflow *.md
recursive-include waveflow/templates *
recursive-include waveflow/assets *

# Exclude Python cache and build artifacts
global-exclude __pycache__/
global-exclude *.pyc
global-exclude *.pyo